{
  "name": "da-clicker-game",
  "private": true,
  "version": "0.1.0",
  "description": "DISCIPLINE. — a PS1-styled red-light idle clicker",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:test": "tsc --noEmit && vite build --mode test",
    "android:test:apk": "npm run build:test && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "test": "node --test tests/*.test.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:local-check": "node scripts/release-check.mjs --local",
    "preview": "vite preview",
    "assemble:cosmetics": "node scripts/assemble-cosmetics.mjs",
    "assemble:blockbench": "node scripts/blockbench-assembly.mjs",
    "assemble:blockbench:all": "node scripts/blockbench-assembly.mjs --all",
    "export:blockbench": "node scripts/export-blockbench-glb.mjs"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capgo/native-purchases": "^8.6.4",
    "@ni2khanna/capacitor-game-connect": "^8.0.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-legacy": "^6.0.0",
    "sharp": "^0.35.3",
    "terser": "^5.49.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
